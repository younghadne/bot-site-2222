FLASK_SECRET_KEY=change-this-to-a-long-random-string
FLASK_ENV=production
PORT=10000

# Optional but strongly recommended on Railway/Render if Instagram blocks cloud logins.
# Use a residential/mobile proxy close to where you normally log in from.
# Format examples:
# IG_PROXY_URL=http://username:password@host:port
# IG_PROXY_URL=socks5://username:password@host:port
IG_PROXY_URL=
