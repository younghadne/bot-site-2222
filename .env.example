# ─────────────────────────────────────────────
#  Instagram Bot — Environment Variables
#  Copy this file to .env and fill in values
#  DO NOT commit .env to git
# ─────────────────────────────────────────────

# Required: any long random string (used to sign cookies)
FLASK_SECRET_KEY=change-this-to-a-long-random-string

# Set to "production" when deploying, "development" locally
FLASK_ENV=production

# Port the server listens on (Render/Railway set this automatically)
PORT=10000
